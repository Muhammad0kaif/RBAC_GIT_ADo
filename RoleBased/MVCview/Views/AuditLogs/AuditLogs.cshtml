@model MVCview.Models.PagedResult<MVCview.Models.AuditLogDto>

@{
    ViewData["Title"] = "Audit Logs";

    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="card shadow border-0 rounded-4">

    <div class="card-body p-4">

        <h2 class="text-primary mb-4">
            Audit Logs
        </h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>UserId</th>
                    <th>Action</th>
                    <th>Timestamp</th>
                    <th>IP</th>
                    <th>View User Logs</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Items != null && Model.Items.Any())
                {
                    foreach (var log in Model.Items)
                    {
                        <tr>
                            <td>@log.Id</td>

                            <td>@log.UserId</td>

                            <td>@log.Action</td>

                            <td>@log.Timestamp.ToString("dd-MM-yyyy HH:mm:ss")</td>

                            <td>@log.IP</td>

                            <td>
                                @if (log.UserId != null)
                                {
                                    <a asp-controller="AuditLogs"
                                       asp-action="UserLogs"
                                       asp-route-userGuid="@log.UserId"
                                       class="btn btn-info btn-sm">
                                        View
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No audit logs found
                        </td>
                    </tr>
                }

            </tbody>

        </table>

        <div class="d-flex justify-content-between mt-3">

            @if (currentPage > 1)
            {
                <a asp-controller="AuditLogs"
                   asp-action="AuditLogs"
                   asp-route-page="@(currentPage - 1)"
                   class="btn btn-secondary">
                    Previous
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>
                    Previous
                </button>
            }

            <span class="fw-bold">
                Page @currentPage  of @totalPages
            </span>

            @if (currentPage < totalPages)
            {
                <a asp-controller="AuditLogs"
                   asp-action="AuditLogs"
                   asp-route-page="@(currentPage + 1)"
                   class="btn btn-secondary">
                    Next
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled>
                    Next
                </button>
            }

        </div>

    </div>

</div>