@model PocoClasses.Dto.UserDto

@{
    var profileImageUrl = !string.IsNullOrEmpty(Model?.ProfilePicture)
        ? $"https://localhost:7050{Model.ProfilePicture.Trim()}?v={DateTime.UtcNow.Ticks}"
        : "https://cdn-icons-png.flaticon.com/512/3135/3135715.png";
}

@if (Model == null)
{
    <div class="alert alert-danger">
        User data not found. Please login again.
    </div>
}
else
{
    <div class="container mt-4">

        <div class="card shadow-lg border-0 rounded-4 p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }
            <div class="text-center mb-4">
                <h2 class="text-primary">My Profile</h2>
            </div>

            <div class="row">

                <div class="col-md-4 text-center">
                    <img src="@profileImageUrl"
                         class="rounded-circle shadow mb-3"
                         width="120"
                         height="120"
                         style="object-fit: cover; background-color: #f8f9fa;"
                         onerror="this.src='https://cdn-icons-png.flaticon.com/512/3135/3135715.png';" />
                    @* @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                    {
                        <img src="https://localhost:7050@Model.ProfilePicture?v=@DateTime.Now.Ticks"
                             class="rounded-circle shadow mb-3"
                             width="120"
                             height="120"
                             style="object-fit: cover;" />
                    }
                    else
                    {
                        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                             class="rounded-circle shadow mb-3"
                             width="120"
                             height="120"
                             style="object-fit: cover;" />
                    } *@

                   

                    <form asp-controller="Profile"
                          asp-action="UploadProfilePicture"
                          method="post"
                          enctype="multipart/form-data">

                        <input type="hidden" name="userId" value="@Model.Id" />

                        <input type="file"
                               name="file"
                               class="form-control form-control-sm mb-2" />

                        <button type="submit"
                                class="btn btn-success btn-sm">
                            Upload Picture
                        </button>

                    </form>

                </div>

                <div class="col-md-8">

                    <table class="table table-borderless">

                        <tr>
                            <th>Name:</th>
                            <td>@Model.Name</td>
                        </tr>

                        <tr>
                            <th>Email:</th>
                            <td>@Model.Email</td>
                        </tr>

                        <tr>
                            <th>Role:</th>
                            <td>
                                <span class="badge bg-success">
                                    @(Model.RoleId == 1 ? "Admin" : "User")
                                </span>
                            </td>
                        </tr>

                    </table>

                    <div class="text-end mt-3">
                        <a asp-controller="Profile"
                           asp-action="Edit"
                           class="btn btn-primary btn-sm">
                            Edit Profile
                        </a>
                        <a asp-controller="Profile"
                           asp-action="ChangePassword"
                           class="btn btn-warning btn-sm ms-2">
                            Change Password
                        </a>
                    </div>
                   

                </div>

            </div>

        </div>

    </div>
}