﻿@using System.Text.Json
@using MVCview.Models


@{
    var permissionsJson = Context.Session.GetString("permissions");

    var permissions = permissionsJson != null
        ? JsonSerializer.Deserialize<List<PermissionDto>>(permissionsJson)
        : new List<PermissionDto>();

    var role = Context.Session.GetString("role");
    var token = Context.Session.GetString("token");

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - RBAC System</title>

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>

            body {
                margin: 0;
                background-color: #f4f6f9;
                font-family: Arial;
            }

            .sidebar {
                height: 100vh;
                background: #212529;
                color: white;
                padding-top: 20px;
                position: fixed;
                width: 240px;
            }

                .sidebar h3 {
                    text-align: center;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: white;
                    text-decoration: none;
                    padding: 12px 20px;
                    margin: 5px 10px;
                    border-radius: 8px;
                    transition: 0.3s;
                }

                    .sidebar a:hover {
                        background-color: #0d6efd;
                    }

            .main-content {
                margin-left: 240px;
            }

            .top-navbar {
                background: white;
                padding: 15px 30px;
                box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            }

            .page-content {
                padding: 30px;
            }

    </style>

</head>

<body>

    
    <div class="sidebar">

        <h3>RBAC</h3>

        @if (permissions != null)
        {
            foreach (var item in permissions)
            {
                if (item.CanRead)
                {
                    @if (item.PageName == "Dashboard")
                    {
                        <a asp-controller="Home" asp-action="Index">Dashboard</a>
                    }
                    else if (item.PageName == "Profile")
                    {
                        <a asp-controller="Profile" asp-action="Profile">Profile</a>
                    }
                    else
                    {
                        <a asp-controller="@item.PageName" asp-action="@item.PageName">
                            @item.PageName
                        </a>
                    }
                }
            }
        }
        @if (role == "Admin")
        {
            <a asp-controller="AuditLogs"
               asp-action="AuditLogs">
                Audit Logs
            </a>
        }

    </div>

    
    <div class="main-content">

        
        <div class="top-navbar d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                Role Based Access Control System
            </h4>

            <div>

                @if (!string.IsNullOrEmpty(role))
                {
                    <span class="me-3 fw-bold text-primary">
                        @role
                    </span>
                }

                @if (!(controller == "Account" && action == "Login"))
                {
                    if (!string.IsNullOrEmpty(token))
                    {
                        <a asp-controller="Account"
                           asp-action="Logout"
                           class="btn btn-danger">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="btn btn-primary">
                            Login
                        </a>
                    }
                }

            </div>

        </div>

        
        <div class="page-content">

            @RenderBody()

        </div>

    </div>

    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>