@model List<MVCview.Models.PasswordHistoryDto>

@{
    ViewData["Title"] = "Password History";
}

<div class="card shadow border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2 class="text-primary mb-0">
                Password History
            </h2>

            <a asp-controller="Users"
               asp-action="Users"
               class="btn btn-secondary">
                Back
            </a>

        </div>

        @if (Model != null && Model.Any())
        {
            <div class="mb-3">
                <p class="mb-1">
                    <strong>User:</strong> @Model.First().UserName
                </p>

                <p class="mb-1">
                    <strong>Email:</strong> @Model.First().Email
                </p>
            </div>
        }

        <div class="alert alert-warning">
            Passwords are not shown in plain text. Only password hashes are displayed for demo/testing.
        </div>

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Password Hash</th>
                    <th>Created At</th>
                </tr>
            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    int count = 1;

                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@count</td>

                            <td style="word-break: break-all;">
                                @item.PasswordHash
                            </td>

                            <td>
                                @item.CreatedAt.ToString("dd-MM-yyyy HH:mm:ss")
                            </td>
                        </tr>

                        count++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            No password history found for this user.
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>