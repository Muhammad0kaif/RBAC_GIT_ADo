@model List<MVCview.Models.UserDto>

@using MVCview.Models


@{
    ViewData["Title"] = "Users";

    var permissions = ViewBag.Permissions as List<PermissionDto>;
    var userPermission = permissions?.FirstOrDefault(p => p.PageName.ToLower() == "users");
}

@{
    var departments = ViewBag.Departments as List<MVCview.Models.DepartmentDto>
        ?? new List<MVCview.Models.DepartmentDto>();

    var role = Context.Session.GetString("role");
}

<div class="card shadow border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2 class="text-primary mb-0">
                Users Management
            </h2>

            @if (userPermission?.CanWrite == true)
            {
                <a asp-controller="Users" asp-action="Create" class="btn btn-success">
                    Create User
                </a>
            }

        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }


        <div class="mb-3">
            <input type="text"
                   id="userSearch"
                   class="form-control"
                   placeholder="Search by name, email, or id..." />
        </div>

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">
                <tr>
                   
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Department</th>
                    <th>Actions</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody id="usersTableBody">

                @foreach (var user in Model)
                {
                    <tr>

                        

                        <td>@user.Name</td>

                        <td>@user.Email</td>
                        <td>
                            @if (user.RoleId == 1)
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else if (user.RoleId == 3)
                            {
                                <span class="badge bg-primary">Manager</span>
                            }
                            else
                            {
                                <span class="badge bg-success">User</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(user.DepartmentName))
                            {
                                <span class="badge bg-info text-dark">
                                    @user.DepartmentName
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    No Department
                                </span>
                            }

                            @if (role == "Admin")
                            {
                                <form asp-controller="Users"
                                      asp-action="TransferDepartment"
                                      method="post"
                                      class="mt-2 d-flex gap-2">

                                    <input type="hidden"
                                           name="userId"
                                           value="@user.Id" />

                                    <select name="departmentId"
                                            class="form-select form-select-sm"
                                            required>

                                        <option value="">Transfer to...</option>

                                        @foreach (var dept in departments)
                                        {
                                            <option value="@dept.Id"
                                                    selected="@(user.DepartmentId == dept.Id)">
                                                @dept.Name
                                            </option>
                                        }

                                    </select>

                                    <button type="submit"
                                            class="btn btn-outline-primary btn-sm"
                                            onclick="return confirm('Transfer this user to selected department?');">
                                        Transfer
                                    </button>

                                </form>
                            }
                        </td>
                        <td>
                            @if (userPermission?.CanWrite == true)
                            {
                                <div class="d-flex flex-wrap gap-2">

                                    <a asp-controller="Users"
                                       asp-action="Edit"
                                       asp-route-id="@user.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form asp-controller="Users"
                                          asp-action="Delete"
                                          asp-route-id="@user.Id"
                                          method="post"
                                          class="m-0">

                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this user?');">
                                            Delete
                                        </button>

                                    </form>

                                    <a asp-controller="Users"
                                       asp-action="PasswordHistory"
                                       asp-route-id="@user.Id"
                                       class="btn btn-info btn-sm text-white">
                                       Password History
                                    </a>

                                </div>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Read Only
                                </span>
                            }
                        </td>
                        <td>
                            @if (user.IsLocked)
                            {
                                <div class="d-flex align-items-center gap-2">

                                    <span class="badge bg-danger px-3 py-2">
                                        Locked
                                    </span>

                                    <form asp-controller="Users"
                                          asp-action="Unlock"
                                          asp-route-id="@user.Id"
                                          method="post"
                                          class="m-0">

                                        <button type="submit"
                                                class="btn btn-outline-success btn-sm"
                                                onclick="return confirm('Unlock this user account?');">
                                            Unlock
                                        </button>

                                    </form>

                                </div>
                            }
                            else
                            {
                                <span class="badge bg-success px-3 py-2">
                                    Active
                                </span>
                            }
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<style>
    .table td,
    .table th {
        vertical-align: middle;
    }

    .table td {
        white-space: normal;
    }

    .btn-sm {
        padding: 5px 12px;
        font-size: 14px;
        border-radius: 6px;
    }

    .badge {
        font-size: 13px;
        border-radius: 6px;
    }
</style>

<script>
    document.getElementById("userSearch").addEventListener("keyup", function () {
        var searchValue = this.value.toLowerCase();

        var rows = document.querySelectorAll("#usersTableBody tr");

        rows.forEach(function (row) {
            var rowText = row.innerText.toLowerCase();

            if (rowText.includes(searchValue)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    });
</script>